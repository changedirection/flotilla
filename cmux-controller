#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["pyyaml"]
# ///
"""cmux-controller: workspace orchestrator for cmux.

Presents a unified fzf picker of web sessions, GitHub issues, and new-blank
options, then sets up a worktree and creates a cmux workspace with the
selected template layout.
"""

import argparse
import copy
import json
import subprocess
import sys
from pathlib import Path

import yaml

# ---------------------------------------------------------------------------
# ANSI helpers
# ---------------------------------------------------------------------------
DIM = "\033[2m"
CYAN = "\033[36m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RESET = "\033[0m"

# ---------------------------------------------------------------------------
# Default template (single pane with {main_command})
# ---------------------------------------------------------------------------
DEFAULT_TEMPLATE: dict = {
    "panes": [
        {"name": "main", "surfaces": [{"command": "{main_command}"}]},
    ],
}


# ---------------------------------------------------------------------------
# Task 1 — repo detection
# ---------------------------------------------------------------------------
def detect_repo_root() -> Path | None:
    """Auto-detect the git repo root via `git rev-parse`."""
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        return Path(result.stdout.strip())
    return None


# ---------------------------------------------------------------------------
# Task 2 — template loading & rendering
# ---------------------------------------------------------------------------
def load_template(repo_root: Path, override: Path | None = None) -> dict:
    """Load a workspace template from file, falling back to DEFAULT_TEMPLATE."""
    path = override if override else repo_root / ".cmux" / "workspace.yaml"
    if path and path.exists():
        with open(path) as f:
            return yaml.safe_load(f)
    return copy.deepcopy(DEFAULT_TEMPLATE)


def render_template(template: dict, variables: dict[str, str]) -> dict:
    """Substitute ``{var}`` placeholders in all command strings."""
    rendered = copy.deepcopy(template)
    for pane in rendered.get("panes", []):
        for surface in pane.get("surfaces", []):
            cmd = surface.get("command", "")
            for key, value in variables.items():
                cmd = cmd.replace(f"{{{key}}}", value)
            surface["command"] = cmd
    return rendered


# ---------------------------------------------------------------------------
# Task 3 — data sources
# ---------------------------------------------------------------------------
def fetch_web_sessions() -> list[dict]:
    """Fetch web sessions from claude.ai API.

    Stubbed until the API endpoint is discovered.  Expected shape per session::

        {
            "type": "web_session",
            "id": "<session-uuid>",
            "title": "Fix auth bug",
            "branch": "robert/fix-auth-bug",
            "repo": "myorg/myrepo",
            "age": "2h ago",
        }
    """
    # TODO: Wire up real API when claude.ai/code session list is available.
    return []


def fetch_github_issues(repo_root: Path) -> list[dict]:
    """Fetch open issues from the current repo via the ``gh`` CLI."""
    try:
        result = subprocess.run(
            [
                "gh", "issue", "list",
                "--json", "number,title,labels,updatedAt",
                "--limit", "20",
                "--state", "open",
            ],
            capture_output=True,
            text=True,
            cwd=repo_root,
        )
    except FileNotFoundError:
        # gh CLI not installed
        return []
    if result.returncode != 0:
        return []
    try:
        issues = json.loads(result.stdout)
    except json.JSONDecodeError:
        return []
    return [
        {
            "type": "issue",
            "id": str(issue["number"]),
            "title": issue["title"],
            "labels": ",".join(
                label["name"] for label in issue.get("labels", [])
            ),
            "age": issue.get("updatedAt", ""),
        }
        for issue in issues
    ]


def new_session_options() -> list[dict]:
    """Return the set of 'create-new' options for the picker."""
    return [
        {
            "type": "new_blank",
            "id": "blank",
            "title": "Blank session (current repo)",
        },
    ]


# ---------------------------------------------------------------------------
# Task 4 — fzf picker
# ---------------------------------------------------------------------------
def format_picker_lines(
    sessions: list[dict],
    new_opts: list[dict],
    issues: list[dict],
) -> list[str]:
    """Build fzf-compatible lines with hidden metadata prefix.

    Format per selectable line: ``type:id<TAB>display_text``
    Section headers have no metadata prefix and are therefore not selectable.
    """
    lines: list[str] = []

    # -- Web Sessions -------------------------------------------------------
    if sessions:
        lines.append(f"{DIM}  Web Sessions{RESET}")
        for s in sessions:
            meta = f"web_session:{s['id']}"
            display = (
                f"    {s['title']:<30s} "
                f"{CYAN}{s.get('branch', ''):<30s}{RESET} "
                f"{s.get('repo', ''):<20s} "
                f"{DIM}{s.get('age', '')}{RESET}"
            )
            lines.append(f"{meta}\t{display}")

    # -- New Session --------------------------------------------------------
    lines.append(f"{DIM}  New Session{RESET}")
    for n in new_opts:
        meta = f"new_blank:{n['id']}"
        lines.append(f"{meta}\t    {GREEN}\u2219 {n['title']}{RESET}")

    # -- GitHub Issues ------------------------------------------------------
    if issues:
        lines.append(f"{DIM}  GitHub Issues{RESET}")
        for i in issues:
            meta = f"issue:{i['id']}"
            labels = (
                f" {DIM}{i['labels']}{RESET}" if i.get("labels") else ""
            )
            lines.append(
                f"{meta}\t    {YELLOW}#{i['id']:<5s}{RESET} "
                f"{i['title']:<45s}{labels}"
            )

    return lines


def run_picker(lines: list[str]) -> str | None:
    """Run fzf with formatted lines; return the metadata prefix of the selection."""
    input_text = "\n".join(lines)
    try:
        result = subprocess.run(
            [
                "fzf",
                "--ansi",
                "--no-sort",
                "--delimiter=\t",
                "--with-nth=2",
                "--header=\u2191\u2193 navigate  enter select  ctrl-c cancel",
                "--prompt=  workspace> ",
                "--pointer=\u25b6",
                "--color=pointer:cyan,prompt:cyan",
            ],
            input=input_text,
            capture_output=True,
            text=True,
        )
    except FileNotFoundError:
        print("Error: fzf is not installed", file=sys.stderr)
        sys.exit(1)

    if result.returncode != 0:
        return None

    selected = result.stdout.strip()
    if "\t" in selected:
        return selected.split("\t", 1)[0]
    return None


# ---------------------------------------------------------------------------
# Task 5 — action dispatch (worktree + cmux workspace)
# ---------------------------------------------------------------------------
CMUX_BIN = "/Applications/cmux.app/Contents/Resources/bin/cmux"


def setup_worktree(
    action_type: str,
    action_id: str,
    repo_root: Path,
    dry_run: bool = False,
) -> tuple[str, Path]:
    """Create or switch to a worktree via the ``wt`` CLI."""
    if action_type == "web_session":
        branch = action_id  # placeholder until API provides branch
        cmd = ["wt", "switch", branch, "--no-cd"]
    elif action_type == "issue":
        branch = f"issue-{action_id}"
        cmd = ["wt", "switch", "--create", branch, "--no-cd"]
    elif action_type == "new_blank":
        branch = input("Branch name: ").strip()
        if not branch:
            print("No branch name provided", file=sys.stderr)
            sys.exit(1)
        cmd = ["wt", "switch", "--create", branch, "--no-cd"]
    else:
        print(f"Unknown action type: {action_type}", file=sys.stderr)
        sys.exit(1)

    if dry_run:
        print(f"[dry-run] {' '.join(cmd)}")
        return branch, repo_root

    result = subprocess.run(cmd, capture_output=True, text=True, cwd=repo_root)
    if result.returncode != 0:
        print(f"wt switch failed: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    # Get worktree path from wt list
    list_result = subprocess.run(
        ["wt", "list", "--format=json"],
        capture_output=True,
        text=True,
        cwd=repo_root,
    )
    if list_result.returncode == 0:
        worktrees = json.loads(list_result.stdout)
        for wt_entry in worktrees:
            if wt_entry.get("branch", "").endswith(branch):
                return branch, Path(wt_entry["path"])

    return branch, repo_root.parent / f"{repo_root.name}.{branch}"


def cmux_run(*args: str, json_output: bool = False) -> str:
    """Run a cmux CLI command and return its stdout."""
    cmd = [CMUX_BIN] + list(args)
    if json_output:
        cmd.insert(1, "--json")
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"cmux error: {' '.join(cmd)}: {result.stderr}", file=sys.stderr)
    return result.stdout.strip()


def create_cmux_workspace(
    template: dict,
    worktree_path: Path,
    dry_run: bool = False,
) -> None:
    """Create a cmux workspace with panes/surfaces defined by *template*."""
    panes = template.get("panes", [])
    if not panes:
        return

    if dry_run:
        print("[dry-run] cmux new-workspace")
        for pane in panes:
            for surface in pane.get("surfaces", []):
                cmd = surface.get("command", "")
                print(f"[dry-run] send: cd {worktree_path} && {cmd}")
        return

    # Create workspace
    ws_output = cmux_run("new-workspace", "--json", json_output=True)
    try:
        ws_data = json.loads(ws_output)
        ws_ref = ws_data.get("workspace", ws_data.get("id", ""))
    except (json.JSONDecodeError, KeyError):
        ws_ref = ""

    pane_refs: dict[str, str] = {}

    for i, pane in enumerate(panes):
        pane_name = pane.get("name", f"pane_{i}")

        if i == 0:
            # First pane already exists in new workspace
            panes_output = cmux_run("list-panes", "--json", json_output=True)
            try:
                pane_list = json.loads(panes_output)
                current_ref = pane_list[-1].get(
                    "ref", pane_list[-1].get("id", "")
                )
            except (json.JSONDecodeError, KeyError, IndexError):
                current_ref = "pane:1"
            pane_refs[pane_name] = current_ref
        else:
            direction = pane.get("split", "right")
            parent_name = pane.get("parent")
            split_args = ["new-split", direction]
            if parent_name and parent_name in pane_refs:
                split_args.extend(["--panel", pane_refs[parent_name]])
            split_output = cmux_run(*split_args, "--json", json_output=True)
            try:
                split_data = json.loads(split_output)
                current_ref = split_data.get(
                    "ref", split_data.get("id", "")
                )
            except (json.JSONDecodeError, KeyError):
                current_ref = f"pane:{i + 1}"
            pane_refs[pane_name] = current_ref

        # Create surfaces within the pane
        surfaces = pane.get("surfaces", [])
        for j, surface in enumerate(surfaces):
            if not (i == 0 and j == 0):
                # First surface of first pane already exists
                cmux_run(
                    "new-surface",
                    "--type",
                    "terminal",
                    "--pane",
                    pane_refs[pane_name],
                )

            cmd = surface.get("command", "")
            full_cmd = (
                f"cd {worktree_path} && {cmd}" if cmd else f"cd {worktree_path}"
            )
            cmux_run("send", full_cmd + "\n")


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
def main() -> None:
    parser = argparse.ArgumentParser(
        description="cmux workspace orchestrator",
    )
    parser.add_argument(
        "--repo-root",
        type=Path,
        default=None,
        help="Git repo root (auto-detected if omitted)",
    )
    parser.add_argument(
        "--template",
        type=Path,
        default=None,
        help="Workspace template file (default: .cmux/workspace.yaml)",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print commands without executing",
    )
    args = parser.parse_args()

    # -- Detect repo root ---------------------------------------------------
    repo_root = args.repo_root or detect_repo_root()
    if not repo_root:
        print("Error: not in a git repository", file=sys.stderr)
        sys.exit(1)

    # -- Fetch data sources -------------------------------------------------
    sessions = fetch_web_sessions()
    new_opts = new_session_options()
    issues = fetch_github_issues(repo_root)

    # -- Run picker ---------------------------------------------------------
    lines = format_picker_lines(sessions, new_opts, issues)
    selection = run_picker(lines)
    if not selection:
        print("Cancelled.")
        sys.exit(0)

    # -- Dispatch selection ---------------------------------------------------
    action_type, action_id = selection.split(":", 1)

    # Determine main_command
    if action_type == "web_session":
        main_command = f"claude --teleport {action_id}"
    elif action_type == "issue":
        title = next(
            (i["title"] for i in issues if i["id"] == action_id), ""
        )
        main_command = f'claude --remote "Fix #{action_id}: {title}"'
    elif action_type == "new_blank":
        main_command = "claude"
    else:
        print(f"Unknown selection: {selection}", file=sys.stderr)
        sys.exit(1)

    # Setup worktree
    branch, wt_path = setup_worktree(
        action_type, action_id, repo_root, args.dry_run
    )

    # Load and render template
    template = load_template(repo_root, args.template)
    rendered = render_template(template, {
        "main_command": main_command,
        "branch": branch,
        "repo": repo_root.name,
        "issue_number": action_id if action_type == "issue" else "",
        "session_id": action_id if action_type == "web_session" else "",
    })

    # Create cmux workspace
    create_cmux_workspace(rendered, wt_path, args.dry_run)
    print(f"Workspace created for {branch} at {wt_path}")


if __name__ == "__main__":
    main()
